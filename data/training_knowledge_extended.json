  "progression_methods": {
    "linear": {
      "description": "Add weight each session",
      "best_for": "beginners",
      "example": "Add 2.5-5kg when target reps achieved for all sets"
    },
    "double_progression": {
      "description": "Build reps within range, then add weight",
      "best_for": "intermediate",
      "example": "Week 1: 8,8,8 → Week 2: 10,9,9 → Week 3: 12,11,10 → Add 5kg, back to 8s"
    },
    "rpe_based": {
      "description": "Train based on rate of perceived exertion",
      "scale": {
        "RPE 6": "4 reps in reserve, warmup weight",
        "RPE 7": "3 reps in reserve, easy working weight",
        "RPE 8": "2 reps in reserve, moderate working weight",
        "RPE 9": "1 rep in reserve, challenging",
        "RPE 10": "0 reps in reserve, maximum effort"
      }
    },
    "percentage_based": {
      "description": "Train based on percentage of 1RM",
      "example": "Week 1: 70%, Week 2: 75%, Week 3: 80%, Week 4: Deload"
    }
