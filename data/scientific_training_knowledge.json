{
  "source": "Based on StrongerByScience meta-analyses, Menno Henselmans research, and 2024-2025 peer-reviewed literature",
  "version": "2.0",
  "last_updated": "2024-03",
  
  "periodization": {
    "description": "周期化训练比非周期化训练在力量增长上快约22%（meta-analysis）",
    
    "linear_periodization": {
      "description": "线性周期化：训练量逐渐降低，强度逐渐增加",
      "best_for": ["beginner", "strength_focus"],
      "mesocycle_length": "4-8 weeks",
      "example": {
        "week_1": { "intensity": "65% 1RM", "reps": "10-12", "volume": "100%" },
        "week_2": { "intensity": "70% 1RM", "reps": "8-10", "volume": "95%" },
        "week_3": { "intensity": "75% 1RM", "reps": "6-8", "volume": "90%" },
        "week_4": { "intensity": "80% 1RM", "reps": "4-6", "volume": "85%" },
        "week_5": { "type": "deload", "intensity": "60% 1RM", "volume": "50%" }
      }
    },
    
    "daily_undulating_periodization": {
      "description": "每日波动周期化：一周内不同训练日使用不同强度",
      "best_for": ["intermediate", "advanced", "trained_lifters"],
      "effectiveness": "对有经验训练者比线性周期化效果好约28%",
      "example_3x_week": {
        "day_1": { "focus": "力量", "intensity": "85-90% 1RM", "reps": "3-5" },
        "day_2": { "focus": "肌肥大", "intensity": "70-75% 1RM", "reps": "8-12" },
        "day_3": { "focus": "力量耐力", "intensity": "55-65% 1RM", "reps": "15-20" }
      }
    },
    
    "weekly_undulating_periodization": {
      "description": "每周波动周期化：不同周使用不同重点",
      "best_for": ["intermediate"],
      "example": {
        "week_1": { "focus": "高容量", "sets": 5, "reps": "8-12", "intensity": "65-70%" },
        "week_2": { "focus": "高强度", "sets": 3, "reps": "3-5", "intensity": "85-90%" },
        "week_3": { "focus": "中等", "sets": 4, "reps": "6-8", "intensity": "75-80%" },
        "week_4": { "type": "deload", "sets": 2, "reps": "8-10", "intensity": "60%" }
      }
    },
    
    "block_periodization": {
      "description": "板块周期化：专注某一适应能力的训练板块",
      "best_for": ["advanced", "athletes"],
      "blocks": {
        "accumulation": { "duration": "2-4 weeks", "focus": "容量积累，动作学习" },
        "transmutation": { "duration": "2-4 weeks", "focus": "专项力量转化" },
        "realization": { "duration": "1-2 weeks", "focus": "巅峰表现/测试" }
      }
    }
  },
  
